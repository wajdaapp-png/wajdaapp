<%- include('partials/header', { title: 'انضم لكباتن واجدة | ترقية الحساب' }) %>

<div class="flex-grow flex items-center justify-center px-4 py-12">
    <div class="max-w-xl w-full bg-kCard border border-kBorder rounded-3xl p-8 shadow-2xl transition-all duration-300 hover:border-kOrange/30">
        
        <div class="text-center mb-8">
            <span class="text-4xl">🚚</span>
            <h1 class="text-3xl font-black text-kOrange tracking-wide mt-3 mb-2">انضم لعائلة كباتن واجدة</h1>
            <p class="text-sm text-kMuted">ابدأ جني الأرباح الكاش حياً واستقبل طلبات الشحن والتسوق القريبة منك</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 p-4 bg-red-900/20 border border-red-500/40 text-red-400 rounded-xl text-xs font-semibold flex items-center gap-2">
                <span>🚨</span>
                <p><%= error %></p>
            </div>
        <% } %>

        <form action="/driver/register" method="POST" enctype="multipart/form-data" class="space-y-6">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="vehicle_type" class="block text-xs font-bold text-kMuted mb-2 mr-1">نوع مركبة التوصيل</label>
                    <select id="vehicle_type" name="vehicle_type" required 
                        class="w-full bg-kBg border border-kBorder text-white rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200 focus:border-kOrange focus:ring-1 focus:ring-kOrange cursor-pointer">
                        <option value="bike" class="bg-kCard">دراجة هوائية 🚲</option>
                        <option value="motorcycle" class="bg-kCard">دراجة نارية 🏍️</option>
                        <option value="car" class="bg-kCard">سيارة سياحية 🚗</option>
                        <option value="van" class="bg-kCard">سيارة نفعية / شاحنة 🚚</option>
                    </select>
                </div>

                <div>
                    <label for="working_city" class="block text-xs font-bold text-kMuted mb-2 mr-1">نطاق ولاية النشاط والبلدية</label>
                    <select id="working_city" name="working_city" required 
                        class="w-full bg-kBg border border-kBorder text-white rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200 focus:border-kOrange focus:ring-1 focus:ring-kOrange cursor-pointer">
                        <option value="" disabled selected class="bg-kCard text-kMuted">اختر الولاية والبلدية التابعة لك...</option>
                        <option value="بسكرة، بسكرة" class="bg-kCard">بسكرة ، وسط المدينة 🎯</option>
                        <option value="بسكرة، ليشانة" class="bg-kCard">بسكرة ، ليشانة 🌴</option>
                        <option value="بسكرة، طولقة" class="bg-kCard">بسكرة ، طولقة 🌴</option>
                        <option value="بسكرة، فوغالة" class="bg-kCard">بسكرة ، فوغالة 🌴</option>
                        <option value="بسكرة، بوشقرون" class="bg-kCard">بسكرة ، بوشقرون 🌴</option>
                        <option value="بسكرة، ليوة" class="bg-kCard">بسكرة ، ليوة 🌴</option>
                        <option value="بسكرة، الحاجب" class="bg-kCard">بسكرة ، الحاجب 🌴</option>
                        <option value="بسكرة، مخادمة" class="bg-kCard">بسكرة ، مخادمة 🌴</option>
                        <option value="بسكرة، مليلي" class="bg-kCard">بسكرة ، مليلي 🌴</option>
                        <option value="بسكرة، أورلال" class="bg-kCard">بسكرة ، أورلال 🌴</option>
                    </select>
                </div>
            </div>

            <div id="legal_docs_section" class="hidden space-y-6 border-t border-kBorder pt-6">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div id="plate_number_wrapper">
                        <label for="vehicle_plate" class="block text-xs font-bold text-kMuted mb-2 mr-1">رقم لوحة الترقيم (الترقيم)</label>
                        <input type="text" id="vehicle_plate" name="vehicle_plate" placeholder="12345 116 07" 
                            class="w-full bg-kBg border border-kBorder text-white rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200 focus:border-kOrange focus:ring-1 focus:ring-kOrange">
                    </div>

                    <div>
                        <label for="license_number" class="block text-xs font-bold text-kMuted mb-2 mr-1">رقم رخصة السياقة</label>
                        <input type="text" id="license_number" name="license_number" placeholder="رقم الرخصة المكتوب بالخلف" 
                            class="w-full bg-kBg border border-kBorder text-white rounded-xl px-4 py-3 text-sm outline-none transition-all duration-200 focus:border-kOrange focus:ring-1 focus:ring-kOrange">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="license_image" class="block text-xs font-bold text-kMuted mb-2 mr-1">صورة رخصة السياقة (واضحة)</label>
                        <input type="file" id="license_image" name="license_image" accept="image/*"
                            class="w-full bg-kBg border border-kBorder text-white rounded-xl px-3 py-2 text-xs outline-none file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-kBorder file:text-white hover:file:bg-kOrange/20 file:cursor-pointer">
                    </div>

                    <div>
                        <label for="vehicle_image" id="vehicle_image_label" class="block text-xs font-bold text-kMuted mb-2 mr-1">صورة بطاقة رمادية / وثيقة المركبة</label>
                        <input type="file" id="vehicle_image" name="vehicle_image" accept="image/*"
                            class="w-full bg-kBg border border-kBorder text-white rounded-xl px-3 py-2 text-xs outline-none file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-kBorder file:text-white hover:file:bg-kOrange/20 file:cursor-pointer">
                    </div>
                </div>

            </div>
            <div class="p-4 bg-kBg border border-kBorder rounded-2xl flex items-start gap-3">
                <span class="text-xl mt-0.5">💡</span>
                <div class="space-y-1">
                    <h4 class="text-xs font-bold text-white">معلومة لوجستية هامة:</h4>
                    <p class="text-[11px] text-kMuted leading-relaxed">بمجرد إرسال الطلب، سيقوم فريق مراجعة واجدة بمعاينة بياناتك وترقية رتبتك في قاعدة البيانات فوراً إلى <span class="text-kOrange font-bold">كابتن معتمد</span> لتتحول تلقائياً من زبون إلى كابتن وتفتح لك لوحة الرادار الحية.</p>
                </div>
            </div>

            <div class="flex items-center gap-2 text-xs font-semibold text-kMuted px-1">
                <input type="checkbox" id="terms" name="terms" required class="accent-kOrange rounded border-kBorder bg-kBg cursor-pointer">
                <label for="terms" class="cursor-pointer select-none">
                    أوافق على كافة <a href="/driver/terms" class="text-kOrange hover:underline font-bold">شروط وقوانين واجدة</a> اللوجستية للكباتن.
                </label>
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-4 pt-2">
                <a href="/driver/logout" 
                    class="w-full sm:w-auto text-center border border-kBorder hover:bg-kBg text-kMuted hover:text-white font-bold text-sm py-3 px-6 rounded-xl transition-all duration-200">
                    إلغاء وتراجع 🔙
                </a>
                <button type="submit" 
                    class="w-full sm:flex-grow bg-kOrange hover:bg-orange-600 text-white font-bold text-sm py-3 px-4 rounded-xl shadow-lg shadow-kOrange/20 transition-all duration-200 transform active:scale-[0.98]">
                    تقديم ملف الترقية فوراً 🚀
                </button>
            </div>
        </form>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const vehicleSelect = document.getElementById('vehicle_type');
        const legalDocsSection = document.getElementById('legal_docs_section');
        const vehicleImageLabel = document.getElementById('vehicle_image_label');
        
        // الحقول المطلوب تفعيل خاصية الـ required عليها ديناميكياً عند الحاجة
        const vehiclePlate = document.getElementById('vehicle_plate');
        const licenseNumber = document.getElementById('license_number');
        const licenseImage = document.getElementById('license_image');
        const vehicleImage = document.getElementById('vehicle_image');

        function toggleVehicleFields() {
            const selectedVehicle = vehicleSelect.value;

            if (selectedVehicle === 'bike') {
                // 1. الدراجة الهوائية: إخفاء حزمة الوثائق تماماً وإلغاء القيود
                legalDocsSection.classList.add('hidden');
                
                vehiclePlate.required = false;
                licenseNumber.required = false;
                licenseImage.required = false;
                vehicleImage.required = false;
            } else {
                // 2. بقية المركبات: إظهار قسم الوثائق فوراً وفرض شروط الإدخال
                legalDocsSection.classList.remove('hidden');
                
                licenseNumber.required = true;
                licenseImage.required = true;
                
                if (selectedVehicle === 'motorcycle') {
                    // الدراجة النارية: تعديل النص التوضيحي وجعل الترقيم اختيارياً حسب نوعها
                    vehicleImageLabel.innerHTML = 'وثيقة الدراجة النارية / كرت الضمان (إن وجد)';
                    vehiclePlate.placeholder = "رقم الترقيم (اتركه فارغاً إن لم يتوفر)";
                    vehiclePlate.required = false;
                    vehicleImage.required = false;
                } else {
                    // السيارات والشاحنات: فرض الترقيم والبطاقة الرمادية قسراً
                    vehicleImageLabel.innerHTML = 'صورة البطاقة الرمادية للمركبة (Carte Grise) 📄';
                    vehiclePlate.placeholder = "12345 116 07";
                    vehiclePlate.required = true;
                    vehicleImage.required = true;
                }
            }
        }

        // الاستماع لحدث التغيير فوراً عند ضغط الكابتن
        vehicleSelect.addEventListener('change', toggleVehicleFields);
        // تشغيل الفحص لمرة واحدة عند تحميل الصفحة لمعالجة الكاش الافتراضي
        toggleVehicleFields();
    });
</script>

<%- include('partials/footer') %>