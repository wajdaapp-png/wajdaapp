<%- include('./partials/header') %> 
<%- include('./partials/sidebar') %>

<div class="space-y-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-xl font-bold text-white flex items-center gap-2" style="font-family: 'Cairo', sans-serif;">
                <i class="fa-solid fa-bell text-[#FF6B00]"></i>
                مركز إدارة الإشعارات والتنبيهات
            </h1>
            <p class="text-xs text-gray-500 mt-1" style="font-family: 'Cairo', sans-serif;">ضخ وإرسال التنبيهات الفورية للكباتن والزبائن ومراقبة التفاعل</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="bg-[#1C1C1C] border border-[#2A2A2A] rounded-2xl p-6 h-fit">
            <h3 class="text-sm font-bold text-white flex items-center gap-2 mb-6" style="font-family: 'Cairo', sans-serif;">
                <i class="fa-solid fa-paper-plane text-[#FF6B00]"></i>
                بث إشعار جديد حياً
            </h3>

            <form id="notificationForm" class="space-y-4 text-right">
                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-2" style="font-family: 'Cairo', sans-serif;">فئة المستهدفين بالبث *</label>
                    <select id="recipient_type" required class="w-full bg-[#111111] border border-[#2A2A2A] text-gray-300 text-xs rounded-xl px-4 py-3 focus:outline-none focus:border-[#FF6B00] transition-all">
                        <option value="" disabled selected>اختر الفئة المستهدفة...</option>
                        <option value="all">الجميع (كباتن وزبائن) 🌐</option>
                        <option value="both">الكباتن فقط (السائقين) 🚗</option>
                        <option value="client">الزبائن فقط (المستخدمين) 👥</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-2" style="font-family: 'Cairo', sans-serif;">عنوان الإشعار *</label>
                    <input type="text" id="title" required placeholder="مثال: تحديث جديد للتطبيق، عرض خاص..." class="w-full bg-[#111111] border border-[#2A2A2A] text-white text-xs rounded-xl px-4 py-3 placeholder-gray-600 focus:outline-none focus:border-[#FF6B00] transition-all">
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-2" style="font-family: 'Cairo', sans-serif;">نص ومحتوى الرسالة *</label>
                    <textarea id="body" rows="4" required placeholder="اكتب تفاصيل الإشعار بدقة هنا..." class="w-full bg-[#111111] border border-[#2A2A2A] text-white text-xs rounded-xl px-4 py-3 placeholder-gray-600 focus:outline-none focus:border-[#FF6B00] transition-all resize-none"></textarea>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-2" style="font-family: 'Cairo', sans-serif;">رابط صورة الإشعار (اختياري)</label>
                    <input type="url" id="image_url" placeholder="https://example.com/image.png" class="w-full bg-[#111111] border border-[#2A2A2A] text-white text-xs rounded-xl px-4 py-3 font-mono placeholder-gray-600 focus:outline-none focus:border-[#FF6B00] transition-all text-left">
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-400 mb-2" style="font-family: 'Cairo', sans-serif;">تاريخ انتهاء صلاحية الإشعار (اختياري)</label>
                    <input type="date" id="expiry_date" class="w-full bg-[#111111] border border-[#2A2A2A] text-gray-300 text-xs rounded-xl px-4 py-3 focus:outline-none focus:border-[#FF6B00] transition-all text-left">
                </div>

                <button type="submit" class="w-full bg-[#FF6B00] hover:bg-[#e05e00] text-white text-xs font-bold py-3.5 rounded-xl transition-all flex items-center justify-center gap-2 mt-4 shadow-lg shadow-[#FF6B00]/10" style="font-family: 'Cairo', sans-serif;">
                    <i class="fa-solid fa-bullhorn text-sm"></i>
                    إطلاق وضخ الإشعار الفوري
                </button>
            </form>
        </div>

        <div class="bg-[#1C1C1C] border border-[#2A2A2A] rounded-2xl p-6 lg:col-span-2">
            <h3 class="text-sm font-bold text-white flex items-center gap-2 mb-6" style="font-family: 'Cairo', sans-serif;">
                <i class="fa-solid fa-clock-rotate-left text-[#FF6B00]"></i>
                سجل الإشعارات السابقة وتحليل التفاعل
            </h3>

            <div class="overflow-x-auto">
                <table class="w-full text-right text-xs text-gray-300">
                    <thead class="text-gray-500 border-b border-[#2A2A2A] bg-[#111111]">
                        <tr>
                            <th class="py-3 px-4">تفاصيل الإشعار</th>
                            <th class="py-3 px-4 text-center">الفئة المستهدفة</th>
                            <th class="py-3 px-4 text-center">تاريخ البث</th>
                            <th class="py-3 px-4 text-center">المشاهدات الحية</th>
                            <th class="py-3 px-4 text-center">إجراءات</th> </tr>
                    </thead>
                    <tbody>
                        <% if (notifications && notifications.length > 0) { %>
                            <% notifications.forEach(noti => { %>
                                <tr class="border-b border-[#2A2A2A]/40 hover:bg-[#111111]/50 transition-all">
                                    <td class="py-4 px-4 max-w-xs">
                                        <div class="flex gap-3 items-start">
                                            <% if (noti.image_url) { %>
                                                <img src="<%= noti.image_url %>" alt="Noti img" class="w-10 h-10 rounded-lg object-cover border border-[#2A2A2A] flex-shrink-0">
                                            <% } else { %>
                                                <div class="w-10 h-10 rounded-lg bg-[#2A2A2A] flex items-center justify-center text-gray-400 flex-shrink-0">
                                                    <i class="fa-solid fa-image text-xs"></i>
                                                </div>
                                            <% } %>
                                            <div class="space-y-1">
                                                <p class="text-white font-semibold line-clamp-1"><%= noti.title %></p>
                                                <p class="text-[11px] text-gray-500 line-clamp-2 leading-relaxed"><%= noti.body %></p>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="py-4 px-4 text-center whitespace-nowrap">
                                        <% if(noti.recipient_type === 'all') { %>
                                            <span class="px-2 py-0.5 rounded text-[10px] bg-blue-500/10 text-blue-400 border border-blue-500/20">الجميع</span>
                                        <% } else if(noti.recipient_type === 'both') { %>
                                            <span class="px-2 py-0.5 rounded text-[10px] bg-purple-500/10 text-purple-400 border border-purple-500/20">الكباتن فقط</span>
                                        <% } else { %>
                                            <span class="px-2 py-0.5 rounded text-[10px] bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">الزبائن فقط</span>
                                        <% } %>
                                    </td>

                                    <td class="py-4 px-4 text-center font-mono text-gray-400 whitespace-nowrap">
                                        <%= new Date(noti.created_at).toLocaleDateString('ar-EG', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                    </td>

                                    <td class="py-4 px-4 text-center font-mono whitespace-nowrap">
                                        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-green-500/5 text-green-400 border border-green-500/15 text-[11px]">
                                            <i class="fa-solid fa-eye text-[10px]"></i>
                                            <%= noti.total_views %> مشاهدة
                                        </div>
                                    </td>

                                    <td class="py-4 px-4 text-center whitespace-nowrap">
                                        <button onclick="deleteNotification('<%= noti.id %>')" class="p-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-lg border border-red-500/20 transition-all cursor-pointer" title="حذف وإلغاء التنبيه نهائياً">
                                            <i class="fa-solid fa-trash-can text-xs"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="py-8 text-center text-gray-500" style="font-family: 'Cairo', sans-serif;">
                                    <i class="fa-solid fa-inbox text-2xl block mb-2 text-gray-600"></i>
                                    لا توجد إشعارات مرسلة مسبقاً في السجل.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    // وظيفة معالجة إرسال النموذج حياً عبر السيرفر
    document.getElementById('notificationForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const submitBtn = this.querySelector('button[type="submit"]');
        const originalBtnText = submitBtn.innerHTML;

        // تفعيل وضع التحميل في الزر
        submitBtn.disabled = true;
        submitBtn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> جاري بث الإشعار...`;

        const data = {
            title: document.getElementById('title').value,
            body: document.getElementById('body').value,
            recipient_type: document.getElementById('recipient_type').value,
            image_url: document.getElementById('image_url').value || null,
            expiry_date: document.getElementById('expiry_date').value || null
        };

        // إرسال الطلب إلى المسار المخصص (تأكد من ربطه بـ Admin Routes لاحقاً)
        fetch('/admin/notifications/create', { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(resData => {
            if(resData.success) {
                alert('تم بث وضخ الإشعار بنجاح لجميع الأجهزة المستهدفة ✅');
                window.location.reload(); // إعادة تحميل الصفحة لتحديث السجل التفاعلي فوراً
            } else {
                alert(resData.message || 'حدث خطأ أثناء محاولة إرسال الإشعار.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
            }
        })
        .catch(err => {
            console.error('Error sending notification:', err);
            alert('خطأ في الاتصال بالسيرفر. يرجى المحاولة مرة أخرى.');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnText;
        });
    });
    function deleteNotification(notiId) {
    if (confirm('⚠️ هل أنت متأكد من مسح هذا الإشعار نهائياً من سجل المنصة وسحبه من هواتف المستخدمين؟')) {
        fetch(`/admin/notifications/delete/${notiId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                window.location.reload(); // إنعاش فوري للسجل
            } else {
                alert(data.message || 'حدث خطأ أثناء محاولة حذف الإشعار.');
            }
        })
        .catch(err => {
            console.error('Error deleting notification:', err);
            alert('خطأ في الاتصال بالخادم.');
        });
    }
}
</script>

<%- include('./partials/footer') %>